
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Organic Agropastoralpi.pi Pi</title>

  <script src="https://sdk.minepi.com/pi-sdk.js"></script>
  <script>
    Pi.init({ version: "2.0", sandbox: true }); // mode test
  </script>
</head>

<body>
  <h1>Organic Agro-pastoralepi.pi</h1>
  <p>Application organicagropastoralepi.pi avec paiement Pi</p>

  <button onclick="login()">Connexion Pi</button>
  <br><br>
  <button onclick="payer()">Payer 1 Pi</button>

  <script>
    let user = null;

    function login() {
      Pi.authenticate(
        ["username"],
        function(auth) {
          user = auth.user;
          alert("Connecté : " + user.username);
        },
        function(error) {
          console.log(error);
        }
      );
    }

    function payer() {
      if (!user) {
        alert("Connecte-toi d'abord");
        return;
      }

      Pi.createPayment({
        amount: 1,
        memo: "Paiement Organic Agropastoralepi.pi",
        metadata: { service: "Agro-pastoralepi.pi" }
      }, {
        onReadyForServerApproval: function(paymentId) {
          console.log("Paiement prêt :", paymentId);
        },
        onReadyForServerCompletion: function(paymentId, txid) {
          alert("Paiement réussi 🎉");
        },
        onCancel: function(paymentId) {
          alert("Paiement annulé");
        },
        onError: function(error) {
          console.log(error);
        }
      });
    }
  </script>
</body>
</html>